{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/justin13888/hash-bench/schema/algorithms.v2.schema.json",
  "title": "hash-bench algorithm catalogue (v2)",
  "description": "The algorithm metadata catalogue emitted by `hash-bench metadata`.",
  "type": "object",
  "required": ["schema_version", "algorithms"],
  "properties": {
    "schema_version": {
      "description": "Algorithms format version. Currently 2.",
      "type": "integer",
      "const": 2
    },
    "algorithms": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "variant",
          "crate",
          "output_bits",
          "output_kind",
          "category",
          "internally_parallel",
          "notes"
        ],
        "properties": {
          "name": {
            "description": "Algorithm display name; joins with benchmark results together with `variant`.",
            "type": "string"
          },
          "variant": {
            "description": "Implementation tag — e.g. \"sw\", \"sha-ext\", \"aes-ext\", \"clmul\", \"crc-ext\". `(name, variant)` is the unique catalogue key.",
            "type": "string"
          },
          "crate": {
            "description": "Backing crate as published on crates.io.",
            "type": "string"
          },
          "output_bits": {
            "description": "Digest width in bits (the benchmarked width for XOFs).",
            "type": "integer",
            "minimum": 1
          },
          "output_kind": {
            "type": "string",
            "enum": ["fixed", "xof"]
          },
          "category": {
            "type": "string",
            "enum": ["cryptographic", "non-cryptographic"]
          },
          "internally_parallel": {
            "description": "Whether the algorithm parallelises a single stream internally.",
            "type": "boolean"
          },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
